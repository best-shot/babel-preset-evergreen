{
  "name": "babel-preset-evergreen",
  "version": "0.11.12",
  "description": "A `babel` preset for modern javascript syntaxes",
  "license": "MIT",
  "author": {
    "name": "Eric Chen"
  },
  "keywords": [
    "babel",
    "babel-preset",
    "best-shot",
    "browser",
    "core-js",
    "evergreen",
    "polyfill",
    "preset",
    "script",
    "shim",
    "transform"
  ],
  "homepage": "https://github.com/best-shot/babel-preset-evergreen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/best-shot/babel-preset-evergreen.git"
  },
  "bugs": {
    "url": "https://github.com/best-shot/babel-preset-evergreen/issues"
  },
  "main": "index.cjs",
  "files": [
    "mini.cjs"
  ],
  "type": "commonjs",
  "scripts": {
    "lint:eslint": "eslint . --quiet --fix --concurrency=auto",
    "lint:staged": "nice-move lint staged",
    "lint:type": "tsc -p tsconfig.json",
    "lint:version": "syncpack lint",
    "prepare": "nice-move git hooks",
    "prepublishOnly": "pnpm run lint:staged && pnpm run lint:type && pnpm test",
    "snapshot": "ava --fail-fast -u",
    "test": "ava --fail-fast",
    "version:pin": "syncpack fix-mismatches"
  },
  "dependencies": {
    "@babel/helper-plugin-utils": "^7.28.6",
    "@babel/preset-env": "^7.29.0",
    "babel-plugin-polyfill-corejs3": "^0.14.0",
    "core-js": "^3.48.0",
    "core-js-compat": "^3.48.0",
    "miniprogram-compat": "^1.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@bring-it/npm": "^0.9.3",
    "@nice-move/all-in-base": "^0.6.37",
    "@types/babel__core": "^7.20.5",
    "ava": "^6.4.1",
    "eslint": "^9.39.2",
    "garou": "^0.9.17",
    "prettier": "~3.8.1",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "@babel/core": "^7.29.0"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": "^10.28.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "ava": {
    "extensions": [
      "mts"
    ]
  },
  "prettier": "@nice-move/prettier-config",
  "x-readme": {
    "logo": "https://cdn.jsdelivr.net/gh/babel/logo/babel.png"
  }
}
